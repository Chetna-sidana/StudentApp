<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_gradient_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="40dp">

        <!-- Logo -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/logo_dark_bg"
            android:gravity="center"
            android:elevation="8dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/global_logo"
                android:scaleType="fitCenter"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join the Skill Exchange community!"
            android:textColor="#E0D4FF"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

        <!-- Progress Bars -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <View
                android:id="@+id/step1Bar"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:background="#FFFFFF"
                android:layout_marginEnd="6dp"/>

            <View
                android:id="@+id/step2Bar"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:background="#FFFFFF40"
                android:layout_marginEnd="6dp"/>

            <View
                android:id="@+id/step3Bar"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:background="#FFFFFF40"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStepLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 3 — Basic Info"
            android:textColor="#E0D4FF"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"/>

        <!-- White Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_white_rounded"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:elevation="16dp">

            <!-- STEP 1 -->
            <LinearLayout
                android:id="@+id/step1Layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤  Full Name"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#7C4DFF"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_bg_gradient"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp">
                    <EditText
                        android:id="@+id/name"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Enter your full name"
                        android:background="@null"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#C0B8E8"
                        android:textSize="14sp"
                        android:singleLine="true"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✉  Email Address"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#7C4DFF"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_bg_gradient"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp">
                    <EditText
                        android:id="@+id/email"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Enter your email"
                        android:background="@null"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#C0B8E8"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"
                        android:singleLine="true"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒  Password"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#7C4DFF"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_bg_gradient"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">
                    <EditText
                        android:id="@+id/password"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Create a password"
                        android:background="@null"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#C0B8E8"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:singleLine="true"/>
                </LinearLayout>

            </LinearLayout>

            <!-- STEP 2 -->
            <LinearLayout
                android:id="@+id/step2Layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱  Mobile Number"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#7C4DFF"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_bg_gradient"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp">
                    <EditText
                        android:id="@+id/mobile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Enter mobile number"
                        android:background="@null"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#C0B8E8"
                        android:textSize="14sp"
                        android:inputType="phone"
                        android:singleLine="true"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍  Location"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#7C4DFF"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_bg_gradient"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">
                    <EditText
                        android:id="@+id/location"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Enter your location"
                        android:background="@null"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#C0B8E8"
                        android:textSize="14sp"
                        android:singleLine="true"/>
                </LinearLayout>

            </LinearLayout>

            <!-- STEP 3 -->
            <LinearLayout
                android:id="@+id/step3Layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎓  Skill to Teach"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#7C4DFF"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_bg_gradient"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp">
                    <EditText
                        android:id="@+id/skillTeach"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="What can you teach?"
                        android:background="@null"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#C0B8E8"
                        android:textSize="14sp"
                        android:singleLine="true"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚  Skill to Learn"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#7C4DFF"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_bg_gradient"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">
                    <EditText
                        android:id="@+id/skillLearn"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="What do you want to learn?"
                        android:background="@null"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#C0B8E8"
                        android:textSize="14sp"
                        android:singleLine="true"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="#7C4DFF"
                android:visibility="gone"
                android:layout_marginTop="16dp"/>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <Button
                    android:id="@+id/btnBack"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:text="← Back"
                    android:textColor="#7C4DFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_outline_gradient"
                    android:layout_marginEnd="10dp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btnNext"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:text="Next →"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_gradient"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>