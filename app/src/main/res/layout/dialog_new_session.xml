<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Schedule Video Session"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="16dp"/>

    <!-- User naam dikhega ID ke jagah -->
    <TextView
        android:id="@+id/tvWithUser"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:textSize="14sp"
        android:textColor="#5C35C9"
        android:textStyle="bold"
        android:background="#EDE7F6"
        android:layout_marginBottom="12dp"/>

    <!-- Hidden - sirf background mein ID store hogi -->
    <EditText
        android:id="@+id/etOtherUserId"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"/>

    <EditText
        android:id="@+id/etSessionTitle"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Session Title e.g. Python Class"
        android:background="#F5F5F5"
        android:padding="12dp"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvSelectedDateTime"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="No date selected"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:textSize="14sp"
        android:textColor="#888888"
        android:background="#F5F5F5"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnPickDateTime"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Pick Date and Time"
        android:backgroundTint="#5C35C9"
        android:textColor="#FFFFFF"/>

</LinearLayout>